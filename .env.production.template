# ======================================================
# Conversa - Production Environment Template
# Copiar como .env y completar los valores
# ======================================================

# ---- Rails ----
SECRET_KEY_BASE=GENERAR_CON_openssl_rand_-hex_64
RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker

# ---- Base URL ----
FRONTEND_URL=https://conversa.oportunidaddevida.com
FORCE_SSL=true

# ---- Base de datos ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=chatwoot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ---- Redis ----
REDIS_URL=redis://:$(REDIS_PASSWORD)@redis:6379
REDIS_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ---- Email (SMTP) ----
MAILER_SENDER_EMAIL=Conversa <noreply@oportunidaddevida.com>
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=TU_EMAIL@gmail.com
SMTP_PASSWORD=TU_APP_PASSWORD
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true

# ---- IA / Captain ----
# Gemini 2.5 Flash (proveedor principal)
GOOGLE_GEMINI_API_KEY=TU_GEMINI_API_KEY

# OpenAI (opcional, fallback)
# CAPTAIN_OPEN_AI_API_KEY=TU_OPENAI_API_KEY

# ---- Almacenamiento (por defecto local) ----
ACTIVE_STORAGE_SERVICE=local
# Para usar S3:
# ACTIVE_STORAGE_SERVICE=amazon
# S3_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# ---- Configuración adicional ----
LOG_LEVEL=info
LOG_SIZE=500
RACK_TIMEOUT_SERVICE_TIMEOUT=60
